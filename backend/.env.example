# Django Settings
ENVIRONMENT=production
DEBUG=False
SECRET_KEY=your-secret-key-here-generate-a-new-one-in-production

# Database Configuration (Supabase PostgreSQL)
# Copy values from Supabase: Project Settings → Database → Connection string

# Option A (recommended for Django): Direct connection
# DB_HOST=db.xxxxxxxxxxxxx.supabase.co
# DB_PORT=5432
# DB_NAME=postgres
# DB_USER=postgres

# Option B: Supabase pooler (Session mode — use port 5432 on pooler host)
# DB_HOST=aws-1-ap-southeast-1.pooler.supabase.com
# DB_PORT=5432
# DB_NAME=postgres
# DB_USER=postgres.your-project-ref
# OR set DB_USER=postgres and DB_PROJECT_REF=your-project-ref

# Option C: Full connection string (overrides individual DB_* vars)
# DATABASE_URL=postgresql://postgres.your-project-ref:password@aws-1-ap-southeast-1.pooler.supabase.com:5432/postgres

DB_NAME=postgres
DB_USER=postgres.your-project-ref
DB_PASSWORD=your-supabase-password
DB_HOST=aws-1-ap-southeast-1.pooler.supabase.com
DB_PORT=5432
# DB_PROJECT_REF=your-project-ref

# Frontend URL
FRONTEND_URL=https://dietplannar.vercel.app

# Allowed Hosts
ALLOWED_HOSTS=your-render-app.onrender.com,localhost,127.0.0.1
