# Django Settings (production template — copy to .env and fill secrets locally)
ENVIRONMENT=production
DEBUG=False
SECRET_KEY=your-secret-key-here

# Database Configuration (Supabase pooler — transaction mode)
DB_ENGINE=postgresql
DB_HOST=aws-1-ap-southeast-1.pooler.supabase.com
DB_NAME=postgres
DB_PORT=6543
DB_USER=postgres
DB_PASSWORD=your-supabase-password

# Required for pooler when DB_USER=postgres (Supabase → Settings → General → Reference ID)
DB_PROJECT_REF=your-project-ref

# Frontend URL
FRONTEND_URL=https://dietplanner.vercel.app

# Allowed Hosts (replace with your actual Render URL)
ALLOWED_HOSTS=your-render-app.onrender.com,localhost
